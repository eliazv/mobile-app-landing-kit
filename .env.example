# Retrieve your GA ID from your GA dashboard
GOOGLE_ANALYTICS_ID=G-XXXXXXX

# Umami tracking (https://umami.is) — leave empty to disable
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Defaults to https://cloud.umami.is/script.js if using Umami Cloud; set to your self-hosted script URL otherwise
NEXT_PUBLIC_UMAMI_SCRIPT_URL=